# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Publisher Frontend — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in the values.
# cp .env.example .env
#
# Vite requires the VITE_ prefix to expose vars to browser code.
# Without this file, the frontend renders a white screen.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_ADMIN_EMAILS=your-email@example.com
