# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Publisher Service — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in the values.
# cp .env.example .env

# Database (same DB as news-pipeline)
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline_secret@localhost:5432/news_pipeline

# Redis (same as news-pipeline — for Celery task management)
REDIS_URL=redis://localhost:6379/0

# Notion CMS
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# Supabase (for admin JWT verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Admin access — comma-separated list of allowed emails
ADMIN_EMAILS=tinfood.rmit@gmail.com
