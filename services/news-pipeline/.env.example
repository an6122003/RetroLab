# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# News Pipeline — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Required ──
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline_secret@localhost:5432/news_pipeline
REDIS_URL=redis://localhost:6379/0

# At least one LLM provider API key is needed:
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...

# ── LLM Provider ──
# Options: gemini, anthropic, ollama
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (set LLM_PROVIDER=ollama to use) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_NUM_CTX=8192
OLLAMA_THINK=true

# ── Image search (optional) ──
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
OPENAI_API_KEY=
ENABLE_DALLE_FALLBACK=false

# ── Pipeline tuning ──
DISCOVERY_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_RUN=50
SCRAPER_DELAY_SECONDS=2
PLAYWRIGHT_HEADLESS=true
LLM_TEMPERATURE=0.7
LOG_LEVEL=INFO
OUTPUT_LANGUAGE=vi
OUTPUT_LANGUAGE_NAME=Vietnamese
