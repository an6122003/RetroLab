# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# News Pipeline — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Required
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/news_pipeline
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...

# Image search — Unsplash/Pexels (optional fallbacks, Google Images scraped for free)
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=


# Optional
OPENAI_API_KEY=
ENABLE_DALLE_FALLBACK=false
DISCOVERY_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_RUN=50
SCRAPER_DELAY_SECONDS=2
PLAYWRIGHT_HEADLESS=true
LLM_TEMPERATURE=0.7
LOG_LEVEL=INFO
OUTPUT_LANGUAGE=vi
OUTPUT_LANGUAGE_NAME=Vietnamese

